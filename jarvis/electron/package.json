{
  "name": "jarvis",
  "version": "1.0.0",
  "description": "JARVIS AI Assistant",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.jarvis.ai",
    "productName": "JARVIS",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "electron-traywindow-positioner": "^1.2.1"
  }
}
