# .env.example - JARVIS Cognitive Operating System
# Copy this file to .env and replace placeholders with local values.
# Never commit real API keys or private credentials.

# =============================================================================
# CORE RUNTIME
# =============================================================================

# Runtime environment: development, staging, production
JARVIS_ENV=development

# Enable extra debug behavior. Keep false for normal use.
JARVIS_DEBUG=false

# Logging level: DEBUG, INFO, WARNING, ERROR
JARVIS_LOG_LEVEL=INFO

# Backend bind host and port
JARVIS_HOST=127.0.0.1
JARVIS_PORT=5000

# Public URL used by desktop launchers and HUD links
JARVIS_PUBLIC_URL=http://127.0.0.1:5000

# Start desktop tray runtime when launched through the desktop entrypoint
JARVIS_TRAY_ENABLED=true

# Open the HUD automatically on startup
JARVIS_OPEN_UI_ON_START=false

# Enable wake-word service on startup
JARVIS_ENABLE_WAKE_ON_START=true

# Enable WebSocket realtime event transport
WEBSOCKET_ENABLED=true
WEBSOCKET_PATH=/ws/events
WEBSOCKET_PING_INTERVAL_SECONDS=20
WEBSOCKET_CLIENT_TIMEOUT_SECONDS=60
WEBSOCKET_MAX_QUEUE_SIZE=1024

# Keep legacy SSE endpoints available during migration
SSE_COMPAT_ENABLED=true

# Enable internal realtime event bus
REALTIME_EVENTS_ENABLED=true
REALTIME_EVENT_HISTORY_LIMIT=1000
REALTIME_EVENT_QUEUE_SIZE=2048
REALTIME_EVENT_DROP_POLICY=drop_oldest

# Enable runtime telemetry and performance tracing
TELEMETRY_ENABLED=true
PERFORMANCE_TELEMETRY_ENABLED=true
TELEMETRY_INCLUDE_PAYLOADS=false


# =============================================================================
# AI PROVIDERS
# =============================================================================

# Provider priority order. Local-first is recommended.
AI_PROVIDER_PRIORITY=ollama,local,openrouter,nvidia,openai,anthropic,gemini

# Prefer local inference before cloud fallback
AI_LOCAL_FIRST=true

# Allow cloud providers when local inference is unavailable
AI_CLOUD_FALLBACK_ENABLED=true

# Prefer free/low-cost providers where possible
AI_FREE_PROVIDER_PREFERENCE=true

# Global provider timeout and retry behavior
AI_CONNECT_TIMEOUT_SECONDS=10
AI_REQUEST_TIMEOUT_SECONDS=30
AI_STREAM_TIMEOUT_SECONDS=180
AI_MAX_RETRIES=2
AI_RETRY_BACKOFF_SECONDS=1.5
AI_PROVIDER_COOLDOWN_SECONDS=60

# Circuit breaker settings for unhealthy providers
AI_CIRCUIT_BREAKER_ENABLED=true
AI_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
AI_CIRCUIT_BREAKER_RECOVERY_SECONDS=120

# Streaming generation settings
AI_STREAMING_ENABLED=true
AI_STREAM_CHUNK_TIMEOUT_SECONDS=30
AI_REQUEST_CANCELLATION_ENABLED=true
AI_BENCHMARK_ON_START=false

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=your_openrouter_model_here

# NVIDIA NIM
NVIDIA_API_KEY=your_nvidia_nim_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_DEFAULT_MODEL=your_nvidia_nim_model_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=your_openai_model_here

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_DEFAULT_MODEL=your_anthropic_model_here

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_DEFAULT_MODEL=your_gemini_model_here

# Ollama local inference
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_DEFAULT_MODEL=llama3.2:3b

# Generic local OpenAI-compatible inference endpoint
LOCAL_INFERENCE_ENABLED=false
LOCAL_INFERENCE_BASE_URL=http://127.0.0.1:8000/v1
LOCAL_INFERENCE_API_KEY=local_placeholder_key
LOCAL_INFERENCE_DEFAULT_MODEL=your_local_model_here


# =============================================================================
# VOICE SYSTEM
# =============================================================================

# Master voice runtime toggle
VOICE_ENABLED=true

# Native backend owns microphone input
AUDIO_MULTIPLEXER_ENABLED=true

# Audio device settings. Use auto unless a fixed device index is required.
AUDIO_INPUT_DEVICE=auto
AUDIO_OUTPUT_DEVICE=auto
AUDIO_INPUT_SAMPLE_RATE=48000
AUDIO_TARGET_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_BLOCKSIZE=2048
AUDIO_QUEUE_SIZE=128
AUDIO_LATENCY_MODE=low

# Wake word: openWakeWord
WAKE_ENABLED=true
WAKE_ENGINE=openwakeword
WAKE_MODEL_PATH=wake/models/hey_jarvis_custom.onnx
WAKE_THRESHOLD=0.60
WAKE_COOLDOWN_SECONDS=2.0
WAKE_ROLLING_WINDOW=3
WAKE_REQUIRE_SPEAKER_VERIFY=false

# Voice activity detection: Silero primary, WebRTC fallback
VAD_ENGINE=silero
SILERO_VAD_ENABLED=true
SILERO_VAD_THRESHOLD=0.50
SILERO_VAD_MIN_SPEECH_MS=250
SILERO_VAD_MIN_SILENCE_MS=500
WEBRTC_VAD_FALLBACK_ENABLED=true
WEBRTC_VAD_AGGRESSIVENESS=3

# Speech-to-text: faster-whisper
STT_ENGINE=faster-whisper
WHISPER_MODEL=tiny.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=en
WHISPER_BEAM_SIZE=3
WHISPER_MAX_DURATION_SECONDS=10
WHISPER_STREAMING_PARTIALS=true

# Text-to-speech: Piper primary, XTTS-v2 fallback
TTS_ENGINE=piper
PIPER_MODEL_PATH=models/tts/piper/en_US-lessac-medium.onnx
PIPER_CONFIG_PATH=models/tts/piper/en_US-lessac-medium.json
PIPER_SPEAKER_ID=0

XTTS_ENABLED=false
XTTS_MODEL_PATH=models/tts/xtts-v2
XTTS_VOICE_SAMPLE_PATH=models/tts/reference_voice.wav

# Streaming and interruption behavior
TTS_SENTENCE_STREAMING=true
TTS_QUEUE_SIZE=16
TTS_MAX_CHARS_PER_UTTERANCE=400
TTS_INTERRUPTIBLE=true
INTERRUPT_DETECTION_ENABLED=true
BARGE_IN_ENABLED=true
BARGE_IN_RMS_THRESHOLD=0.02
AUDIO_DUCKING_ENABLED=true
AUDIO_DUCKING_LEVEL=0.35

# Voice latency targets and diagnostics
WAKE_TO_RESPONSE_TARGET_MS=300
VOICE_DEBUG_AUDIO=false
VOICE_SAVE_DEBUG_CLIPS=false
VOICE_DEBUG_CLIP_DIR=logs/audio


# =============================================================================
# MEMORY SYSTEM
# =============================================================================

# Master memory toggle
MEMORY_ENABLED=true

# Legacy JSON memory compatibility
MEMORY_FILE=memory_store.json

# Local memory data paths
MEMORY_DATA_DIR=data/memory
MEMORY_ARCHIVE_DIR=data/memory/archive

# Chroma vector memory
CHROMA_ENABLED=true
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION=jarvis_memory

# SQLite hybrid memory store
SQLITE_MEMORY_ENABLED=true
SQLITE_MEMORY_PATH=data/jarvis_memory.sqlite3

# Embedding model
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# Retrieval and retention
MEMORY_TOP_K=5
MEMORY_MAX_EPISODES=500
MEMORY_WORKING_TTL_SECONDS=3600
MEMORY_IMPORTANCE_THRESHOLD=0.45
MEMORY_RETRIEVAL_MIN_SCORE=0.25
MEMORY_RECENCY_HALFLIFE_DAYS=14
MEMORY_RETENTION_DAYS=365

# Consolidation, summarization, and pruning
MEMORY_CONSOLIDATION_ENABLED=true
MEMORY_CONSOLIDATION_INTERVAL_MINUTES=60
MEMORY_SUMMARIZATION_ENABLED=true
MEMORY_SUMMARIZE_AFTER_EPISODES=25
MEMORY_SUMMARY_MAX_TOKENS=800
MEMORY_PRUNING_ENABLED=true
MEMORY_PRUNE_INTERVAL_HOURS=24
MEMORY_WRITE_ASYNC=true


# =============================================================================
# PERCEPTION / COWORK MODE
# =============================================================================

# Master cowork intelligence toggle
COWORK_MODE_ENABLED=false

# Screen capture service
SCREEN_CAPTURE_ENABLED=false
SCREEN_CAPTURE_BACKEND=dxcam
SCREEN_CAPTURE_FPS=1
SCREEN_CAPTURE_MIN_CHANGE_RATIO=0.08
SCREENSHOT_DIR=data/vision/screenshots

# Frame sampler cadence
FRAME_SAMPLER_ENABLED=true
FRAME_SAMPLER_MIN_INTERVAL_MS=1000
FRAME_SAMPLER_IDLE_INTERVAL_MS=5000

# OCR pipeline
OCR_ENABLED=false
OCR_ENGINE=paddleocr
PADDLEOCR_LANG=en
PADDLEOCR_USE_GPU=false
OCR_CADENCE_SECONDS=5

# Vision-language model pipeline
VLM_ENABLED=false
VLM_PRIMARY_MODEL=Qwen2.5-VL-local
VLM_FALLBACK_MODEL=MiniCPM-V-local
VLM_ENDPOINT=http://127.0.0.1:8001/v1
VLM_TIMEOUT_SECONDS=30

# Workspace awareness
ACTIVE_WINDOW_TRACKING_ENABLED=true
WINDOW_TRACKING_CADENCE_SECONDS=1
BROWSER_AWARENESS_ENABLED=true
IDE_AWARENESS_ENABLED=true
TERMINAL_AWARENESS_ENABLED=true

# Visual memory policy: summaries_only, key_frames, ephemeral
SCREENSHOT_RETENTION_POLICY=summaries_only
SCREENSHOT_RETENTION_DAYS=7
SCREENSHOT_SAVE_HIGH_VALUE_EVENTS=false
VISUAL_MEMORY_ENABLED=true
VISUAL_MEMORY_STORE_IMAGES=false


# =============================================================================
# WORLD MODEL / AUTONOMY
# =============================================================================

# Persistent world model
WORLD_MODEL_ENABLED=true
WORLD_STATE_PATH=data/world_state.json
ENVIRONMENT_GRAPH_ENABLED=true
ENVIRONMENT_GRAPH_PATH=data/environment_graph.sqlite3

# Active workspace and project continuity
ACTIVE_PROJECT_TRACKING_ENABLED=true
ACTIVE_DOCUMENT_TRACKING_ENABLED=true
TERMINAL_SESSION_TRACKING_ENABLED=true
BROWSER_WORKFLOW_TRACKING_ENABLED=true

# Workflow and habit learning
WORKFLOW_LEARNING_ENABLED=true
WORKFLOW_PATTERN_MIN_OCCURRENCES=3
WORKFLOW_PATTERN_CONFIDENCE_THRESHOLD=0.75

# Proactivity: quiet_recall, contextual_nudges, autonomous_prep
PROACTIVITY_LEVEL=contextual_nudges
PROACTIVE_SUGGESTIONS_ENABLED=true
CONTEXTUAL_STARTUP_RECOVERY=true
RESUME_SUGGESTIONS_ENABLED=true

# Temporal reasoning
TEMPORAL_REASONING_ENABLED=true
TEMPORAL_CONTEXT_LOOKBACK_DAYS=30

# Autonomous reasoning runtime
AUTONOMOUS_RUNTIME_ENABLED=true
AUTONOMOUS_MODE_DEFAULT=ASSIST
AUTONOMOUS_REPLAN_LIMIT=3
AUTONOMOUS_CONFIRM_VISIBLE_ACTIONS=true

# Long-running task runtime
LONG_TASK_RUNTIME_ENABLED=true
LONG_TASK_MAX_ACTIVE=3
LONG_TASK_MAX_STEPS=50
LONG_TASK_MAX_RUNTIME_MINUTES=120
LONG_TASK_CHECKPOINT_INTERVAL_SECONDS=300
LONG_TASK_REFLECTION_INTERVAL_STEPS=5
LONG_TASK_CHECKPOINT_PATH=data/long_tasks

# Goal memory
GOAL_MEMORY_ENABLED=true
GOAL_CHECKPOINT_PATH=data/goals.json


# =============================================================================
# SKILL LEARNING / SELF-OPTIMIZATION
# =============================================================================

# Learn successful and failed execution patterns
SELF_OPTIMIZATION_ENABLED=true
SKILL_GRAPH_ENABLED=true
EXECUTION_PATTERN_MINER_ENABLED=true
WORKFLOW_COMPRESSION_ENABLED=true

# Learned skills are suggested first; they are not auto-enabled by default.
LEARNED_SKILL_PROMOTION_POLICY=suggest_first
LEARNED_SKILL_OUTPUT_DIR=skills/learned
LEARNED_SKILL_MIN_SUCCESS_COUNT=3
LEARNED_SKILL_MIN_CONFIDENCE=0.80

# Adaptive retries and latency learning
ADAPTIVE_RETRY_ENABLED=true
ADAPTIVE_RETRY_MAX_ATTEMPTS=3
LATENCY_LEARNING_ENABLED=true
LATENCY_REGRESSION_THRESHOLD_MS=1500

# Provider optimization feeds router scores without random fallback loops
PROVIDER_OPTIMIZATION_ENABLED=true
PROVIDER_OPTIMIZATION_WINDOW=50


# =============================================================================
# PRESENCE / INTERACTION LAYER
# =============================================================================

# Ambient presence: silent_hud, subtle_presence, expressive_presence
PRESENCE_MODE=subtle_presence
PRESENCE_ENABLED=true

# Conversational cadence
CADENCE_ENGINE_ENABLED=true
NATURAL_PAUSES_ENABLED=true
ACKNOWLEDGEMENT_THROTTLE_SECONDS=20
INTERRUPTION_AWARE_CADENCE=true

# Dynamic voice profiles by operating mode
DYNAMIC_VOICE_PROFILES_ENABLED=true
VOICE_PROFILE_DEFAULT=assist
VOICE_PROFILE_FOCUS=minimal
VOICE_PROFILE_CODER=technical
VOICE_PROFILE_RESEARCH=analytical

# Ambient awareness and reactive HUD
AMBIENT_AWARENESS_ENABLED=true
IDLE_PRESENCE_ENABLED=true
IDLE_PRESENCE_INTERVAL_SECONDS=300
ENVIRONMENTAL_RESPONSES_ENABLED=true


# =============================================================================
# SECURITY / PRIVACY
# =============================================================================

# Force local-only behavior. When true, cloud providers and cloud vision should be disabled.
LOCAL_ONLY_MODE=false
ALLOW_CLOUD_PROVIDERS=true

# Sensitive-window and auth-page filtering
SENSITIVE_WINDOW_FILTER_ENABLED=true
SENSITIVE_WINDOW_PATTERNS=*password*,*bank*,*checkout*,*2fa*,*auth*,*login*,*private*
AUTH_PAGE_DETECTION_ENABLED=true

# Perception privacy
EPHEMERAL_PERCEPTION_MODE=true
CLIPBOARD_CAPTURE_ENABLED=false
PRIVATE_BROWSING_DETECTION_ENABLED=true

# Redaction
TOKEN_REDACTION_ENABLED=true
SECRET_REDACTION_ENABLED=true
LOG_REDACTION_ENABLED=true
REDACTION_PLACEHOLDER=[REDACTED]

# Memory privacy
MEMORY_PRIVACY_MODE=summaries_only
MEMORY_STORE_RAW_TRANSCRIPTS=false
MEMORY_STORE_SCREENSHOTS=false
MEMORY_STORE_BROWSER_URLS=false
MEMORY_STORE_TERMINAL_OUTPUT=false

# Diagnostics and crash safety
CRASH_REPORT_INCLUDE_CONTEXT=false
API_KEY_PRINT_GUARD=true


# =============================================================================
# FRONTEND / HUD
# =============================================================================

# HUD identity
HUD_ENABLED=true
HUD_MODE=ironman
HUD_HOSTED_BY_BACKEND=true

# Refresh rates
HUD_TELEMETRY_REFRESH_MS=5000
HUD_SYSTEM_REFRESH_MS=8000
HUD_EVENT_STREAM_RECONNECT_MS=3000

# Realtime visuals
HUD_REALTIME_ANIMATIONS=true
HUD_WAKE_VISUALS=true
HUD_AUDIO_VISUALIZER_ENABLED=true
HUD_PARTICLES_ENABLED=true
HUD_SCANLINES_ENABLED=true

# Cowork overlay
HUD_COWORK_OVERLAY_ENABLED=false
HUD_COWORK_OVERLAY_POSITION=right
HUD_COWORK_MAX_SUGGESTIONS=3

# Debug visuals
HUD_VISUAL_DEBUG=false
HUD_SHOW_PROVIDER_BADGES=true
HUD_MAX_EVENT_ROWS=5
HUD_TOAST_DURATION_MS=4000
